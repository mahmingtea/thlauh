{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "thlauh!",
  "version": "0.0.3",
  "identifier": "com.mahmingtea.thlauh-share",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "thlauh!",
        "width": 800,
        "height": 600,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEyNjlBNkVBMTUxODBDQkUKUldTK0RCZ1Y2cVpwb2hjZUoxQ3dMem90L25MazcxY2ovWHQwejQ4NmhzTlJ0Z1lKeTRQSGpJcnUK",
      "endpoints": [
        "https://raw.githubusercontent.com/mahmingtea/thlauh/main/updater/latest.json"
      ]
    }
  }
}
